<Window x:Class="VMCSpoutSettingWPF.CameraPlusSetup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VMCSpoutSettingWPF"
        mc:Ignorable="d"
        Title="CameraPlusSetup" Height="450" Width="400" ResizeMode="NoResize" Topmost="True">
    <Grid Margin="8,8,8,8" >
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Button x:Name="BeatSaberFolderButton" Content="Select BeatSaber Folder" Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="2" Click="BeatSaberFolderButton_Click" />
        <TextBlock Text="BeatSaber Folder" VerticalAlignment="Center" HorizontalAlignment="Left" Grid.Row="1" />
        <TextBox x:Name="BeatSaberFolderTextBox" Grid.Column="0" Grid.ColumnSpan="4" VerticalAlignment="Stretch" Grid.Row="2" TextChanged="BeatSaberFolderTextBox_TextChanged"/>

        <ListView ItemsSource="{x:Null}" x:Name="ProfileListBox" Grid.Column="0" Grid.ColumnSpan="4" VerticalAlignment="Stretch" Grid.Row="5" Margin="0,0,0,8">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListViewItem">
                                <CheckBox IsChecked="{Binding IsEnabled}" Content="{Binding Name}" />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>

        <TextBlock Text="Profile List" VerticalAlignment="Center" HorizontalAlignment="Left" Grid.Row="4" />
        <Button x:Name="SetupButton" Content="CameraPlus Setup" Grid.Column="2" Grid.Row="6" Grid.ColumnSpan="2" Click="SetupButton_Click" />

    </Grid>
</Window>
