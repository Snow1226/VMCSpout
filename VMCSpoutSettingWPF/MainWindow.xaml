<Window x:Class="VMCSpoutSettingWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VMCSpoutSettingWPF"
        mc:Ignorable="d"
        Title="VMCSpout Setting" Height="450" Width="600" ResizeMode="NoResize" Topmost="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Label Content="MainCamera" Grid.Row="0" Grid.Column="0" VerticalAlignment="Top" HorizontalAlignment="Left" Grid.ColumnSpan="2" />
        <Label Content=" Spout Name:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Top" HorizontalAlignment="Left" Grid.ColumnSpan="2"/>
        <Label Content=" Width  :" Grid.Row="3" Grid.Column="0" VerticalAlignment="Top" HorizontalAlignment="Left"/>
        <Label Content=" Height :" Grid.Row="4" Grid.Column="0" VerticalAlignment="Top" HorizontalAlignment="Left" />

        <Label Content="Mirror Resolution:" Grid.Row="1" Grid.Column="3" VerticalAlignment="Top" HorizontalAlignment="Right" Grid.ColumnSpan="2"/>
        <Label Content="Mirror Width (m) :" Grid.Row="2" Grid.Column="3" VerticalAlignment="Top" HorizontalAlignment="Right" Grid.ColumnSpan="2" />
        <Label Content="Mirror Height (m) :" Grid.Row="3" Grid.Column="3" VerticalAlignment="Top" HorizontalAlignment="Right" Grid.ColumnSpan="2" />

        <TextBox x:Name="MainCameraSpoutNameTextBox" Grid.Row="2" Grid.Column="1" VerticalAlignment="Stretch"  Margin="0,2,0,2" Grid.ColumnSpan="2"/>
        <TextBox x:Name="MainCameraWidthTextBox" Grid.Row="3" Grid.Column="1" VerticalAlignment="Stretch" Margin="0,2,0,2" Grid.ColumnSpan="2"/>
        <TextBox x:Name="MainCameraHeightTextBox" Grid.Row="4" Grid.Column="1" VerticalAlignment="Stretch"  Margin="0,2,0,2" Grid.ColumnSpan="2"/>

        <CheckBox x:Name="UseMirrorCheckBox" Content="Use Mirror" Grid.Row="0" Grid.Column="4" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,2,30,2" Grid.ColumnSpan="2"/>
        <TextBox x:Name="MirrorResolutionTextBox" Grid.Row="1" Grid.Column="5" VerticalAlignment="Stretch" Margin="0,2,0,2" Grid.ColumnSpan="2"/>
        <TextBox x:Name="MirrorWidthTextBox" Grid.Row="2" Grid.Column="5" VerticalAlignment="Stretch"  Margin="0,2,0,2" Grid.ColumnSpan="2"/>
        <TextBox x:Name="MirrorHeightTextBox" Grid.Row="3" Grid.Column="5" VerticalAlignment="Stretch"  Margin="0,2,0,2" Grid.ColumnSpan="2"/>

        <CheckBox x:Name="UseMirrorFollowCheckBox" Content="Follow Mirror Poistion" Grid.Row="0" Grid.Column="8" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,2,0,2" Grid.ColumnSpan="3"/>
        <Label Content="Center Position:" Grid.Row="1" Grid.Column="8" VerticalAlignment="Top" HorizontalAlignment="Left" Grid.ColumnSpan="2"/>
        <Label Content="x:" Grid.Row="2" Grid.Column="8" VerticalAlignment="Top" HorizontalAlignment="Left" Grid.ColumnSpan="2"/>
        <Label Content="y:" Grid.Row="2" Grid.Column="9" VerticalAlignment="Top" HorizontalAlignment="Left" Grid.ColumnSpan="2"/>
        <Label Content="z:" Grid.Row="2" Grid.Column="10" VerticalAlignment="Top" HorizontalAlignment="Left" Grid.ColumnSpan="2"/>
        <TextBox x:Name="MirrorCenterPositionXTextBox" Grid.Row="2" Grid.Column="8" VerticalAlignment="Stretch"  Margin="18,2,0,2" Grid.ColumnSpan="1"/>
        <TextBox x:Name="MirrorCenterPositionYTextBox" Grid.Row="2" Grid.Column="9" VerticalAlignment="Stretch"  Margin="18,2,0,2" Grid.ColumnSpan="1"/>
        <TextBox x:Name="MirrorCenterPositionZTextBox" Grid.Row="2" Grid.Column="10" VerticalAlignment="Stretch"  Margin="18,2,0,2" Grid.ColumnSpan="1"/>

        <Label Content="Center Rotation:(-180～+180)" Grid.Row="3" Grid.Column="8" VerticalAlignment="Top" HorizontalAlignment="Left" Grid.ColumnSpan="3"/>
        <TextBox x:Name="MirrorCenterRotationYTextBox" Grid.Row="4" Grid.Column="9" VerticalAlignment="Stretch"  Margin="0,2,0,2" Grid.ColumnSpan="1"/>


        <DataGrid x:Name="SpoutDataGrid" Grid.Row="6" AutoGenerateColumns="False" CanUserAddRows="True" CanUserDeleteRows="True" SelectionMode="Single" SelectionUnit="FullRow" Grid.ColumnSpan="11">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Spout Name" Binding="{Binding SpoutName}" Width="*"/>
                <DataGridTextColumn Header="VMCP Port" Binding="{Binding Port}" Width="*"/>
                <DataGridTextColumn Header="Width" Binding="{Binding OutputWidth}" Width="*"/>
                <DataGridTextColumn Header="Height" Binding="{Binding OutputHeight}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Button x:Name="ApplyButton" Content="Apply" Grid.Row="7" Grid.Column="8" Margin="2,2,2,2" Click="ApplyButton_Click" Grid.ColumnSpan="3" Width="120" HorizontalAlignment="Right"/>
    </Grid>
</Window>
